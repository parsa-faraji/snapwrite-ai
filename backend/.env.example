# AI Provider: "openai" or "anthropic" (default: openai)
AI_PROVIDER=openai

# Provide at least one API key:
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Port (default 3001)
PORT=3001

# Optional: Allowed origins (comma-separated, default "*")
# Set to your Chrome extension ID in production:
# ALLOWED_ORIGINS=chrome-extension://your-extension-id
ALLOWED_ORIGINS=*
